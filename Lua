        local center    = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        local tbRadius  = Options["TriggerbotRadius"]         and Options["TriggerbotRadius"].Value         or 25
        local thickness = Options["TriggerbotFOVThickness"]   and Options["TriggerbotFOVThickness"].Value   or 2
        local transp    = Options["TriggerbotFOVTransparency"]and Options["TriggerbotFOVTransparency"].Value or 50
        local col1      = Options["TriggerbotFOVColor"]       and Options["TriggerbotFOVColor"].Value       or Color3.new(1,0,0)
        local col2      = Options["TriggerbotFOVColor2"]      and Options["TriggerbotFOVColor2"].Value      or Color3.fromRGB(255,120,120)
        local filled    = Toggles["TriggerbotFOVFilled"]      and Toggles["TriggerbotFOVFilled"].Value

        local spinT     = (math.sin(TBFOVSpinAngle) + 1) / 2
        local animColor = col1:Lerp(col2, spinT)

        TBFOVCircle.Visible      = true
        TBFOVCircle.Position     = center
        TBFOVCircle.Radius       = tbRadius
        TBFOVCircle.Thickness    = thickness
        TBFOVCircle.Transparency = 1 - ((100 - transp) / 100)
        TBFOVCircle.Color        = animColor
        TBFOVCircle.Filled       = filled

        if filled then
            local fc1 = Options["TriggerbotFOVFillColor"]  and Options["TriggerbotFOVFillColor"].Value  or Color3.fromRGB(255,0,0)
            local fc2 = Options["TriggerbotFOVFillColor2"] and Options["TriggerbotFOVFillColor2"].Value or Color3.fromRGB(120,0,0)
            local ft  = Options["TriggerbotFOVFillTransp"] and Options["TriggerbotFOVFillTransp"].Value or 60
            TBFOVCircle.Color        = fc1:Lerp(fc2, spinT)
            TBFOVCircle.Transparency = 1 - ((100 - ft) / 100)
        end
    else
        TBFOVCircle.Visible = false
    end
end

