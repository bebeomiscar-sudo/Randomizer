local function TriggerbotCheck()
    if not Toggles["TriggerbotEnabled"] or not Toggles["TriggerbotEnabled"].Value then return end
    if not TriggerbotKeyActive() then return end
    if TriggerOnCooldown then return end

    local tbRadius  = Options["TriggerbotRadius"]   and Options["TriggerbotRadius"].Value   or 25
    local minDelay  = (Options["TriggerbotMinDelay"] and Options["TriggerbotMinDelay"].Value or 50)  / 1000
    local maxDelay  = (Options["TriggerbotMaxDelay"] and Options["TriggerbotMaxDelay"].Value or 120) / 1000
    local baseDelay = (Options["TriggerbotClickHold"]and Options["TriggerbotClickHold"].Value or 30) / 1000
    local visCheck  = Toggles["TriggerbotVisCheck"] and Toggles["TriggerbotVisCheck"].Value
    local teamCheck = Toggles["TeamCheck"]           and Toggles["TeamCheck"].Value
    local bones     = GetTriggerbotBones()

    local center    = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end
        if not IsAlive(player) then continue end
        if teamCheck and player.Team == LP.Team then continue end

        local char = GetCharacter(player)
        if not char then continue end

        -- Katana check
        if Toggles["KatanaCheck"] and Toggles["KatanaCheck"].Value then
            local tool = char:FindFirstChildOfClass("Tool")
            if tool and tool.Name:lower():find("katana") then continue end
        end

        for _, boneName in ipairs(bones) do
            local part = GetBonePart(char, boneName)
            if not part then continue end

            -- Visibility check
            if visCheck and not CanSeeTarget(Camera.CFrame.Position, part.Position) then continue end

            local screenPos, onScreen = WorldToViewport(part.Position)
            if not onScreen then continue end

            if (screenPos - center).Magnitude <= tbRadius then
                -- Target in crosshair → fire
                TriggerOnCooldown = true
                local rndDelay = minDelay + math.random() * (maxDelay - minDelay)

                task.delay(rndDelay, function()
                    TriggerFire(part.Position, part)
                    task.delay(baseDelay, function()
                        TriggerOnCooldown = false
                    end)
                end)
                return
            end
        end
    end
end

