-- HitTarget nil instance finder (from DEX)
local function GetNilInstance(Name, DebugId)
    if not getnilinstances then return nil end
    for _, obj in ipairs(getnilinstances()) do
        if obj.Name == Name then
            if DebugId then
                if obj:GetDebugId() == DebugId then
                    return obj
                end
            else
                return obj
            end
        end
    end
    return nil
end

