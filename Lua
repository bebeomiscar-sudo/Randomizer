-- [[ ORBIT AUTO BUILD ON TOGGLE ]]
-- ============================================================
Toggles["OrbitEnabled"]:OnChanged(function(v)
    if v then
        local count = math.floor(Opt("OrbitCount") or 6)
        _G.OrbitRebuild(count)
    else
        _G.OrbitCleanup()
    end
end)

Options["OrbitCount"]:OnChanged(function(v)
    if Get("OrbitEnabled") then
        _G.OrbitRebuild(math.floor(v))
    end
end)

-- Rebuild on shape change
Options["OrbitShape"]:OnChanged(function()
    if Get("OrbitEnabled") then
        _G.OrbitRebuild(math.floor(Opt("OrbitCount") or 6))
    end
end)

