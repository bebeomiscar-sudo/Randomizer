        if root then
            local ok = pcall(function()
                -- Fire as a hitbox kill shot at head position
                local head = targetChar:FindFirstChild("Head") or root
                PartHitboxRemote:FireServer(
                    CFrame.new(head.Position),
                    Vector3.new(10, 10, 10),
                    Color3.new(1, 0, 0),
                    Enum.PartType.Ball,
                    0,
                    0,
                    "Hitbox"
                )
            end)
            if ok then return true end
        end
    end

    -- Method 3: GunServer.LoadShot on their character's gun
    local tool = LP.Character and LP.Character:FindFirstChildOfClass("Tool")
    if tool then
        local gunServer = tool:FindFirstChild("GunServer")
        if gunServer then
            local loadShot = gunServer:FindFirstChild("LoadShot")
            if loadShot then
                local root = GetRootPart(targetChar)
