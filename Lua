-- Path: ReplicatedStorage.Remotes.Replication.Fighter.UseItem
local function FindUseItemRemote()
    local ok, remote = pcall(function()
        return ReplicatedStorage
            :WaitForChild("Remotes",    10)
            :WaitForChild("Replication",10)
            :WaitForChild("Fighter",    10)
            :WaitForChild("UseItem",    10)
    end)
    if ok and remote then
        UseItemRemote = remote
        print("[creep.cc] UseItem remote found!")
    else
        warn("[creep.cc] UseItem remote NOT found - check path")
    end
end

