function SpawnTracer(fromPos, toPos)
    if not Toggles["HitTracersEnabled"] or not Toggles["HitTracersEnabled"].Value then return end

    local color     = Options["HitTracerColor"]    and Options["HitTracerColor"].Value    or Color3.fromRGB(0,255,255)
    local thickness = Options["HitTracerThickness"]and Options["HitTracerThickness"].Value or 8
    local lifetime  = (Options["HitTracerLifetime"]and Options["HitTracerLifetime"].Value or 75)  / 1000
    local fadeIn    = (Options["HitTracerFadeIn"]  and Options["HitTracerFadeIn"].Value   or 5)   / 1000
    local fadeOut   = (Options["HitTracerFadeOut"] and Options["HitTracerFadeOut"].Value  or 35)  / 1000

    local screenFrom, onFrom = WorldToViewport(fromPos)
    local screenTo,   onTo   = WorldToViewport(toPos)
    if not onFrom and not onTo then return end

    local line         = Drawing.new("Line")
    line.Visible       = true
    line.From          = screenFrom
    line.To            = screenTo
    line.Color         = color
    line.Thickness     = thickness
    line.Transparency  = 1

    task.spawn(function()
        local steps = 10
        for i = 1, steps do
            if not line then return end
            line.Transparency = 1 - (i / steps)
            task.wait(fadeIn / steps)
        end
        task.wait(lifetime)
        for i = 1, steps do
            if not line then return end
            line.Transparency = i / steps
            task.wait(fadeOut / steps)
        end
        line:Remove()
    end)
end

