-- [[ SILENT AIM - CrosshairHandler Hook ]]
-- Hooks CrosshairHandler.GetPosition so every shot snaps
-- to closest enemy without moving your camera
-- ============================================================
local SilentAimHooked   = false
local OriginalGetPosition = nil

local function HookSilentAim()
    if SilentAimHooked then return end
    if not CrosshairHandler then return end
    if not CrosshairHandler.GetPosition then return end

    OriginalGetPosition = CrosshairHandler.GetPosition

    hookfunction(CrosshairHandler.GetPosition, function(Self, Tool)
        -- Only redirect if Silent Aim is enabled
        if not Toggles["SilentAim"] or not Toggles["SilentAim"].Value then
            return OriginalGetPosition(Self, Tool)
        end

        local myChar = GetCharacter(LP)
        if not myChar then return OriginalGetPosition(Self, Tool) end

        local wallCheck = Toggles["AimbotWallcheck"] and Toggles["AimbotWallcheck"].Value
        local teamCheck = Toggles["TeamCheck"]        and Toggles["TeamCheck"].Value
        local maxDist   = Options["AimbotMaxDistance"] and Options["AimbotMaxDistance"].Value or 300
        local fovRadius = Options["AimbotFOV"]         and Options["AimbotFOV"].Value         or 120
        local bones     = GetAimbotBones()

        local bestPart   = nil
        local bestDist   = math.huge
        local center     = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

        for _, player in ipairs(Players:GetPlayers()) do
            if player == LP then continue end
            if not IsAlive(player) then continue end
            if teamCheck and player.Team == LP.Team then continue end

            local char = GetCharacter(player)
            if not char then continue end

            local root = GetRootPart(char)
            if not root then continue end

            local dist3D = (root.Position - Camera.CFrame.Position).Magnitude
            if dist3D > maxDist then continue end

            for _, boneName in ipairs(bones) do
                local part = GetBonePart(char, boneName)
                if not part then continue end

                -- Visibility check for silent aim
                if wallCheck and not CanSeeTarget(Camera.CFrame.Position, part.Position) then continue end

                local screenPos, onScreen = WorldToViewport(part.Position)
                if not onScreen then continue end

                local distCenter = (screenPos - center).Magnitude
                if distCenter > fovRadius then continue end

                if distCenter < bestDist then
                    bestDist = distCenter
                    bestPart = part
                end
            end
        end

        if bestPart then
            SilentAimTarget = bestPart
            -- Return the bone world position as the crosshair position
            -- This makes every shot register on target without camera movement
            return bestPart.Position, bestPart
        end

        SilentAimTarget = nil
        return OriginalGetPosition(Self, Tool)
    end)

    SilentAimHooked = true
    print("[creep.cc] Silent Aim hooked via CrosshairHandler.GetPosition")
end

