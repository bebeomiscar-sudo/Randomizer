local LastCameraCF    = nil
local RecoilThreshold = 0.4

local function ApplyNoRecoil()
    if not Toggles["NoRecoil"] or not Toggles["NoRecoil"].Value then
        LastCameraCF = Camera.CFrame
        return
    end
    if LastCameraCF then
        local curLook  = Camera.CFrame.LookVector
        local prevLook = LastCameraCF.LookVector
        local dot      = math.clamp(curLook:Dot(prevLook), -1, 1)
        local angleDelta = math.deg(math.acos(dot))
        if angleDelta > RecoilThreshold and angleDelta < 45 then
            Camera.CFrame = Camera.CFrame:Lerp(LastCameraCF, 0.65)
            return
        end
    end
    LastCameraCF = Camera.CFrame
end

