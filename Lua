local function UpdateLockOn(dt)
    local enabled = Toggles["LockOnEnabled"] and Toggles["LockOnEnabled"].Value

    if not enabled then
        CleanupLockOnMotors()
        return
    end

    local myChar = GetCharacter(LP)
    if not myChar then CleanupLockOnMotors() return end

    local myRoot = GetRootPart(myChar)
    if not myRoot then CleanupLockOnMotors() return end

    -- Auto-select closest if no target
    if not _G.LockOnTarget or not IsAlive(_G.LockOnTarget) then
        local teamCheck  = Toggles["LockOnTeamCheck"] and Toggles["LockOnTeamCheck"].Value
        local maxDist    = Options["LockOnDistance"]   and Options["LockOnDistance"].Value or 300
        local bestPlayer = nil
        local bestDist   = math.huge

        for _, player in ipairs(Players:GetPlayers()) do
            if player == LP then continue end
            if not IsAlive(player) then continue end
            if teamCheck and player.Team == LP.Team then continue end

            local char = GetCharacter(player)
            if not char then continue end
            local root = GetRootPart(char)
            if not root then continue end

            local d = (root.Position - myRoot.Position).Magnitude
            if d < maxDist and d < bestDist then
                bestDist   = d
                bestPlayer = player
            end
        end
        _G.LockOnTarget = bestPlayer
    end

    if not _G.LockOnTarget then
        CleanupLockOnMotors()
        return
    end

    local targetChar = GetCharacter(_G.LockOnTarget)
    if not targetChar then CleanupLockOnMotors() _G.LockOnTarget = nil return end

    local boneName   = Options["LockOnBone"] and Options["LockOnBone"].Value or "UpperTorso"
    local targetPart = GetBonePart(targetChar, boneName)
    if not targetPart then CleanupLockOnMotors() return end

    -- Setup motors if missing
    if not LockOnBodyPos or not LockOnBodyPos.Parent then
        SetupLockOnMotors(myRoot)
    end

    local targetPos = targetPart.Position

    -- Move character body toward target using BodyPosition
    -- Camera stays completely independent
    LockOnBodyPos.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    LockOnBodyPos.Position = targetPos

    -- Rotate character to face target (body, not camera)
    local lookDir = (targetPos - myRoot.Position)
    if lookDir.Magnitude > 0.1 then
        local faceCF = CFrame.lookAt(myRoot.Position, myRoot.Position + Vector3.new(lookDir.X, 0, lookDir.Z))
        LockOnBodyGyro.MaxTorque = Vector3.new(0, 1e5, 0)
        LockOnBodyGyro.CFrame   = faceCF
    end
end

