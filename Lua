local function UpdateUtilityESP()
    if not Toggles["UtilityESPEnabled"] or not Toggles["UtilityESPEnabled"].Value then
        for _, obj in pairs(UtilityESPObjects) do
            if obj.Label then obj.Label.Visible = false end
            if obj.Glow  then obj.Glow.Visible  = false end
        end
        return
    end

    local showName = Toggles["UtilityESPName"] and Toggles["UtilityESPName"].Value
    local showGlow = Toggles["UtilityESPGlow"] and Toggles["UtilityESPGlow"].Value
    local espColor = Options["UtilityESPColor"]and Options["UtilityESPColor"].Value or Color3.fromRGB(0,255,120)

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Tool") and not obj:FindFirstAncestorOfClass("Backpack") and not obj:FindFirstAncestorOfClass("Character") then
            local handle = obj:FindFirstChild("Handle")
            if not handle then continue end

            if not UtilityESPObjects[obj] then
                UtilityESPObjects[obj] = {
                    Label = Drawing.new("Text"),
                    Glow  = Drawing.new("Circle"),
                }
                UtilityESPObjects[obj].Label.Size    = 14
                UtilityESPObjects[obj].Label.Center  = true
                UtilityESPObjects[obj].Label.Outline = true
            end

            local screenPos, onScreen = WorldToViewport(handle.Position)
            if onScreen then
                UtilityESPObjects[obj].Label.Visible  = showName
                UtilityESPObjects[obj].Label.Text     = obj.Name
                UtilityESPObjects[obj].Label.Position = screenPos - Vector2.new(0, 20)
                UtilityESPObjects[obj].Label.Color    = espColor
                UtilityESPObjects[obj].Glow.Visible      = showGlow
                UtilityESPObjects[obj].Glow.Position     = screenPos
                UtilityESPObjects[obj].Glow.Radius       = 8
                UtilityESPObjects[obj].Glow.Color        = espColor
                UtilityESPObjects[obj].Glow.Filled       = true
                UtilityESPObjects[obj].Glow.Transparency = 0.5
            else
                if UtilityESPObjects[obj].Label then UtilityESPObjects[obj].Label.Visible = false end
                if UtilityESPObjects[obj].Glow  then UtilityESPObjects[obj].Glow.Visible  = false end
            end
        end
    end

    for obj, drawObj in pairs(UtilityESPObjects) do
        if not obj or not obj.Parent then
            if drawObj.Label then drawObj.Label:Remove() end
            if drawObj.Glow  then drawObj.Glow:Remove()  end
            UtilityESPObjects[obj] = nil
        end
    end
end

