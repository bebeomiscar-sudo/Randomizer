-- [[ INFINITE AMMO ]]
-- ============================================================
local function UpdateInfAmmo()
    if not Toggles["InfAmmo"] or not Toggles["InfAmmo"].Value then return end
    local char = GetCharacter(LP)
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return end

    -- Also check backpack
    for _, t in ipairs({tool, LP.Backpack}) do
        if not t then continue end
        local searchIn = t == LP.Backpack and LP.Backpack:GetChildren() or {t}
        for _, item in ipairs(searchIn) do
            if not item:IsA("Tool") and item ~= tool then continue end
            local target = item == tool and tool or item
            for _, v in ipairs(target:GetDescendants()) do
                if v:IsA("IntValue") or v:IsA("NumberValue") then
                    local n = v.Name:lower()
                    if n:find("ammo") or n:find("mag") or n:find("clip") or n:find("bullet") then
                        if v.Value < 9999 then v.Value = 9999 end
                    end
                end
            end
            -- Also try UpdateAmmo remote
            local gs = target:FindFirstChild("GunServer")
            if gs then
                local updateAmmo = gs:FindFirstChild("UpdateAmmo")
                if updateAmmo then
                    pcall(function()
                        updateAmmo:FireServer(9999, 9999)
                    end)
                end
            end
        end
    end
end

