    if LockOnClickConn then LockOnClickConn:Disconnect() end

    -- Restore silent aim
    if SilentAimHooked and CrosshairHandler and OriginalGetPosition then
        CrosshairHandler.GetPosition = OriginalGetPosition
    end

    -- Restore DamageHandler
    if GodModeHooked and DamageHandler and OriginalDealDamage then
        DamageHandler.DealDamage = OriginalDealDamage
    end

    -- Restore ProjectileHandler
    if ProjectileHandler and OriginalFireRef then
        ProjectileHandler.Fire = OriginalFireRef
    end

    -- Remove ESP
    for _, player in ipairs(Players:GetPlayers()) do
        DestroyESPForPlayer(player)
        local char = GetCharacter(player)
        if char then RestoreHitbox(char) end
    end

    -- Remove drawings
    FOVCircle:Remove()
    TBFOVCircle:Remove()

    for _, obj in pairs(UtilityESPObjects) do
        if obj.Label then obj.Label:Remove() end
        if obj.Glow  then obj.Glow:Remove()  end
    end
    table.clear(UtilityESPObjects)

    -- Restore chams
    for part, orig in pairs(ChammedParts) do
        if part and part.Parent then
            part.Material     = orig.Material
            part.Transparency = orig.Transparency
            part.Color        = orig.Color
        end
    end
    table.clear(ChammedParts)

    -- Restore lighting
    for k, v in pairs(OrigLighting) do
        Lighting[k] = v
    end

    -- Cleanup lock on motors
    CleanupLockOnMotors()

    print("[creep.cc] Fully unloaded.")
end)

return function() bc:Unload() end
