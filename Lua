local function GetBestAimbotTarget()
    local myChar = GetCharacter(LP)
    if not myChar then return nil, nil end

    local wallCheck    = Toggles["AimbotWallcheck"] and Toggles["AimbotWallcheck"].Value
    local teamCheck    = Toggles["TeamCheck"]        and Toggles["TeamCheck"].Value
    local doPrediction = Toggles["AimbotPrediction"] and Toggles["AimbotPrediction"].Value
    local predictScale = Options["AimbotPredictScale"] and Options["AimbotPredictScale"].Value or 8
    local maxDist      = Options["AimbotMaxDistance"]  and Options["AimbotMaxDistance"].Value  or 300
    local fovRadius    = Options["AimbotFOV"]          and Options["AimbotFOV"].Value          or 120
    local bones        = GetAimbotBones()

    local bestPlayer  = nil
    local bestPart    = nil
    local bestDist    = math.huge
    local center      = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end
        if not IsAlive(player) then continue end
        if teamCheck and player.Team == LP.Team then continue end

        local char = GetCharacter(player)
        if not char then continue end

        local root = GetRootPart(char)
        if not root then continue end

        local dist3D = (root.Position - Camera.CFrame.Position).Magnitude
        if dist3D > maxDist then continue end

        for _, boneName in ipairs(bones) do
            local part = GetBonePart(char, boneName)
            if not part then continue end

            local targetPos  = doPrediction and PredictPosition(part, 500, predictScale) or part.Position
            local screenPos, onScreen = WorldToViewport(targetPos)
            if not onScreen then continue end

            local distCenter = (screenPos - center).Magnitude
            if distCenter > fovRadius then continue end

            if wallCheck and not CanSeeTarget(Camera.CFrame.Position, targetPos) then continue end

            if distCenter < bestDist then
                bestDist   = distCenter
                bestPlayer = player
                bestPart   = part
            end
        end
    end

    return bestPlayer, bestPart
end

local function ApplyAimbot(dt)
    if not Toggles["AimbotEnabled"] or not Toggles["AimbotEnabled"].Value then return end
    if not AimbotKeyActive() then return end

    -- If silent aim is on, don't move camera (silent aim handles targeting)
    if Toggles["SilentAim"] and Toggles["SilentAim"].Value then return end

    local _, bestPart = GetBestAimbotTarget()
    if not bestPart then return end

    local doPrediction = Toggles["AimbotPrediction"] and Toggles["AimbotPrediction"].Value
    local predictScale = Options["AimbotPredictScale"] and Options["AimbotPredictScale"].Value or 8
    local smoothing    = Options["AimbotSmoothing"]    and Options["AimbotSmoothing"].Value    or 15
    local sensitivity  = Options["AimbotSensitivityify"]and Options["AimbotSensitivityify"].Value or 1

    local targetPos = doPrediction and PredictPosition(bestPart, 500, predictScale) or bestPart.Position
    local targetCF  = CFrame.new(Camera.CFrame.Position, targetPos)
    local alpha     = math.clamp((sensitivity / smoothing) * dt * 60, 0.01, 1)

    Camera.CFrame = Camera.CFrame:Lerp(targetCF, alpha)
end

