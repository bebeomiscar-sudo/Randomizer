-- ============================================================
local function ApplyWeaponChams()
    local enabled   = Toggles["WeaponChamsEnabled"]    and Toggles["WeaponChamsEnabled"].Value
    local matStr    = Options["WeaponChamsMaterial"]   and Options["WeaponChamsMaterial"].Value   or "ForceField"
    local transpVal = (Options["WeaponChamsTransparency"]and Options["WeaponChamsTransparency"].Value or 0) / 100
    local chamColor = Options["WeaponChamsColor"]      and Options["WeaponChamsColor"].Value      or Color3.new(1,1,1)
    local matEnum   = Enum.Material[matStr] or Enum.Material.ForceField

    local char = GetCharacter(LP)
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")

    if not tool or not enabled then
        for part, orig in pairs(ChammedParts) do
            if part and part.Parent then
                part.Material     = orig.Material
                part.Transparency = orig.Transparency
                part.Color        = orig.Color
            end
        end
        if not enabled then table.clear(ChammedParts) end
        return
    end

    for _, part in ipairs(tool:GetDescendants()) do
        if part:IsA("BasePart") then
            if not ChammedParts[part] then
                ChammedParts[part] = {
                    Material     = part.Material,
                    Transparency = part.Transparency,
                    Color        = part.Color,
                }
            end
            part.Material     = matEnum
            part.Transparency = transpVal
            part.Color        = chamColor
        end
    end
end

