-- [[ LOCK ON SYSTEM ]]
-- Moves character's HumanoidRootPart toward target, not camera
-- Uses BodyPosition / AlignPosition to push character body
-- ============================================================
local LockOnBodyPos = nil
local LockOnBodyGyro= nil

local function SetupLockOnMotors(rootPart)
    -- Clean old
    if LockOnBodyPos  then LockOnBodyPos:Destroy()  end
    if LockOnBodyGyro then LockOnBodyGyro:Destroy() end

    local bp = Instance.new("BodyPosition")
    bp.Name          = "_LockOnBP"
    bp.MaxForce      = Vector3.new(0, 0, 0) -- will be set when active
    bp.P             = 1e4
    bp.D             = 1e3
    bp.Position      = rootPart.Position
    bp.Parent        = rootPart
    LockOnBodyPos    = bp

    local bg = Instance.new("BodyGyro")
    bg.Name          = "_LockOnBG"
    bg.MaxTorque     = Vector3.new(0, 0, 0)
    bg.P             = 1e4
    bg.D             = 1e3
    bg.CFrame        = rootPart.CFrame
    bg.Parent        = rootPart
    LockOnBodyGyro   = bg
end

local function CleanupLockOnMotors()
    if LockOnBodyPos  then LockOnBodyPos:Destroy();  LockOnBodyPos  = nil end
    if LockOnBodyGyro then LockOnBodyGyro:Destroy(); LockOnBodyGyro = nil end
end

