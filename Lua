local SkeletonBones = {
    {"Head","UpperTorso"},
    {"UpperTorso","LowerTorso"},
    {"UpperTorso","RightUpperArm"},
    {"RightUpperArm","RightLowerArm"},
    {"RightLowerArm","RightHand"},
    {"UpperTorso","LeftUpperArm"},
    {"LeftUpperArm","LeftLowerArm"},
    {"LeftLowerArm","LeftHand"},
    {"LowerTorso","RightUpperLeg"},
    {"RightUpperLeg","RightLowerLeg"},
    {"RightLowerLeg","RightFoot"},
    {"LowerTorso","LeftUpperLeg"},
    {"LeftUpperLeg","LeftLowerLeg"},
    {"LeftLowerLeg","LeftFoot"},
}

local function CreateESPForPlayer(player)
    if ESPObjects[player] then return end
    local obj = {
        Box      = Drawing.new("Square"),
        BoxFill  = Drawing.new("Square"),
        Distance = Drawing.new("Text"),
        Name     = Drawing.new("Text"),
        Corners  = {},
        Skeleton = {},
    }
    for i = 1, 8 do  obj.Corners[i]  = Drawing.new("Line") end
    for i = 1, #SkeletonBones do obj.Skeleton[i] = Drawing.new("Line") end

    obj.Box.Thickness   = 1
    obj.Box.Filled      = false
    obj.BoxFill.Filled  = true
    obj.Distance.Size   = 13
    obj.Distance.Center = true
    obj.Distance.Outline= true
    obj.Name.Size       = 13
    obj.Name.Center     = true
    obj.Name.Outline    = true

    ESPObjects[player] = obj
end

local function DestroyESPForPlayer(player)
    local obj = ESPObjects[player]
    if not obj then return end
    obj.Box:Remove()
    obj.BoxFill:Remove()
    obj.Distance:Remove()
    obj.Name:Remove()
    for _, l in ipairs(obj.Corners)  do l:Remove() end
    for _, l in ipairs(obj.Skeleton) do l:Remove() end
    ESPObjects[player] = nil
end

local function HideESP(obj)
    obj.Box.Visible     = false
    obj.BoxFill.Visible = false
    obj.Distance.Visible= false
    obj.Name.Visible    = false
    for _, l in ipairs(obj.Corners)  do l.Visible = false end
    for _, l in ipairs(obj.Skeleton) do l.Visible = false end
end

local function GetAnimatedColor(player, animMode, animSpeed)
    local col1    = Options["ESPVisibleColor"]    and Options["ESPVisibleColor"].Value    or Color3.new(0,1,0)
    local col2    = Options["ESPGradientColor2"]  and Options["ESPGradientColor2"].Value  or Color3.fromRGB(0,200,255)
    local hidCol  = Options["ESPInvisibleColor"]  and Options["ESPInvisibleColor"].Value  or Color3.new(1,0,0)

    local char    = GetCharacter(player)
    local isVis   = false
    if char then
        local root = GetRootPart(char)
        if root then isVis = CanSeeTarget(Camera.CFrame.Position, root.Position) end
    end

    if animMode == "Static" then
        return isVis and col1 or hidCol
    elseif animMode == "Rainbow" then
        return Color3.fromHSV((tick() * animSpeed) % 1, 1, 1)
    elseif animMode == "Spinning Gradient" then
        local t = (math.sin(tick() * animSpeed) + 1) / 2
        return (isVis and col1 or hidCol):Lerp(col2, t)
    elseif animMode == "Pulse" then
        local t = (math.sin(tick() * animSpeed * 2) + 1) / 2
        return (isVis and col1 or hidCol):Lerp(Color3.new(1,1,1), t * 0.5)
    end
    return col1
end

local function UpdateESP()
    local espOn      = Toggles["ESPEnabled"]      and Toggles["ESPEnabled"].Value
    local showFriend = Toggles["ShowFriendlyESP"] and Toggles["ShowFriendlyESP"].Value
    local boxOn      = Toggles["ESPBox"]          and Toggles["ESPBox"].Value
    local cornerOn   = Toggles["ESPCornerBox"]    and Toggles["ESPCornerBox"].Value
    local fillOn     = Toggles["ESPFilled"]       and Toggles["ESPFilled"].Value
    local distOn     = Toggles["ESPDistance"]     and Toggles["ESPDistance"].Value
    local skelOn     = Toggles["ESPSkeleton"]     and Toggles["ESPSkeleton"].Value
    local maxDist    = Options["ESPMaxDistance"]       and Options["ESPMaxDistance"].Value       or 300
    local boxThick   = Options["ESPBoxThickness"]      and Options["ESPBoxThickness"].Value      or 1
    local skelThick  = Options["ESPSkeletonThickness"] and Options["ESPSkeletonThickness"].Value or 1
    local fillTransp = Options["ESPFillTransp"]        and Options["ESPFillTransp"].Value        or 70
    local animMode   = Options["ESPAnimMode"]          and Options["ESPAnimMode"].Value          or "Spinning Gradient"
    local animSpeed  = Options["ESPAnimSpeed"]         and Options["ESPAnimSpeed"].Value         or 1
    local distColor  = Options["ESPDistanceColor"]     and Options["ESPDistanceColor"].Value     or Color3.new(1,1,1)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end

        if not espOn then
            if ESPObjects[player] then HideESP(ESPObjects[player]) end
            continue
        end

        if not showFriend and LP.Team and player.Team == LP.Team then
            if ESPObjects[player] then HideESP(ESPObjects[player]) end
            continue
        end

        if not IsAlive(player) then
            if ESPObjects[player] then HideESP(ESPObjects[player]) end
            continue
        end

        CreateESPForPlayer(player)
        local obj  = ESPObjects[player]
        local char = GetCharacter(player)
        if not char then HideESP(obj) continue end

        local root = GetRootPart(char)
        if not root then HideESP(obj) continue end

        local dist3D = (root.Position - Camera.CFrame.Position).Magnitude
        if dist3D > maxDist then HideESP(obj) continue end

        local head    = char:FindFirstChild("Head") or root
        local headPos, headOn = WorldToViewport(head.Position + Vector3.new(0, 0.7, 0))
        local feetPos, feetOn = WorldToViewport(root.Position - Vector3.new(0, 3, 0))

        if not headOn and not feetOn then HideESP(obj) continue end

        local color = GetAnimatedColor(player, animMode, animSpeed)
        local boxH  = math.abs(headPos.Y - feetPos.Y)
        local boxW  = boxH * 0.65
        local boxX  = headPos.X - boxW / 2
        local boxY  = headPos.Y

        -- Box
        if boxOn then
            obj.Box.Visible   = true
            obj.Box.Size      = Vector2.new(boxW, boxH)
            obj.Box.Position  = Vector2.new(boxX, boxY)
            obj.Box.Color     = color
            obj.Box.Thickness = boxThick
        else obj.Box.Visible = false end

        -- Filled
        if fillOn then
            obj.BoxFill.Visible      = true
            obj.BoxFill.Size         = Vector2.new(boxW, boxH)
            obj.BoxFill.Position     = Vector2.new(boxX, boxY)
            obj.BoxFill.Color        = color
            obj.BoxFill.Transparency = 1 - ((100 - fillTransp) / 100)
        else obj.BoxFill.Visible = false end

        -- Corner box
        if cornerOn then
            local cLen  = boxW * 0.25
            local corners = {
                {Vector2.new(boxX, boxY),               Vector2.new(boxX + cLen, boxY)},
                {Vector2.new(boxX, boxY),               Vector2.new(boxX, boxY + cLen)},
                {Vector2.new(boxX + boxW, boxY),        Vector2.new(boxX + boxW - cLen, boxY)},
                {Vector2.new(boxX + boxW, boxY),        Vector2.new(boxX + boxW, boxY + cLen)},
                {Vector2.new(boxX, boxY + boxH),        Vector2.new(boxX + cLen, boxY + boxH)},
                {Vector2.new(boxX, boxY + boxH),        Vector2.new(boxX, boxY + boxH - cLen)},
                {Vector2.new(boxX + boxW, boxY + boxH), Vector2.new(boxX + boxW - cLen, boxY + boxH)},
                {Vector2.new(boxX + boxW, boxY + boxH), Vector2.new(boxX + boxW, boxY + boxH - cLen)},
            }
            for i, ld in ipairs(corners) do
                obj.Corners[i].Visible   = true
                obj.Corners[i].From      = ld[1]
                obj.Corners[i].To        = ld[2]
                obj.Corners[i].Color     = color
                obj.Corners[i].Thickness = boxThick
            end
        else for _, l in ipairs(obj.Corners) do l.Visible = false end end

        -- Distance
        if distOn then
            obj.Distance.Visible  = true
            obj.Distance.Text     = string.format("[%.0f]", dist3D)
            obj.Distance.Position = Vector2.new(headPos.X, feetPos.Y + 2)
            obj.Distance.Color    = distColor
        else obj.Distance.Visible = false end

        -- Name
        obj.Name.Visible  = true
        obj.Name.Text     = player.DisplayName
        obj.Name.Position = Vector2.new(headPos.X, headPos.Y - 16)
        obj.Name.Color    = color

        -- Skeleton
        if skelOn then
            for i, pair in ipairs(SkeletonBones) do
                local pA = char:FindFirstChild(pair[1])
                local pB = char:FindFirstChild(pair[2])
                if pA and pB then
                    local sA, onA = WorldToViewport(pA.Position)
                    local sB, onB = WorldToViewport(pB.Position)
                    if onA and onB then
                        obj.Skeleton[i].Visible   = true
                        obj.Skeleton[i].From      = sA
                        obj.Skeleton[i].To        = sB
                        obj.Skeleton[i].Color     = color
                        obj.Skeleton[i].Thickness = skelThick
                    else obj.Skeleton[i].Visible = false end
                else obj.Skeleton[i].Visible = false end
            end
        else for _, l in ipairs(obj.Skeleton) do l.Visible = false end end
    end
end

