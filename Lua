-- ============================================================
local function ExpandHitbox(char, size)
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and not part:HasTag("GunKitExpanded") then
            CollectionService:AddTag(part, "GunKitExpanded")
            ExpandedParts[part] = { OrigSize = part.Size }
            part.Size = Vector3.new(size, size, size)
        end
    end
end

local function RestoreHitbox(char)
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part:HasTag("GunKitExpanded") then
            CollectionService:RemoveTag(part, "GunKitExpanded")
            if ExpandedParts[part] then
                part.Size = ExpandedParts[part].OrigSize
                ExpandedParts[part] = nil
            end
        end
    end
end

local function UpdateHitboxes()
    local enabled = Toggles["HitboxExpander"] and Toggles["HitboxExpander"].Value
    local size    = Options["HitboxSize"]     and Options["HitboxSize"].Value     or 5
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end
        local char = GetCharacter(player)
        if not char then continue end
        if enabled and IsAlive(player) then
            ExpandHitbox(char, size)
        else
            RestoreHitbox(char)
        end
    end
end

